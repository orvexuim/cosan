# ══════════════════════════════════════════════════
#   COSMAN Backend — Environment Variables
#   Copy to backend/.env — never commit .env
# ══════════════════════════════════════════════════

# ── App ──
NODE_ENV=development
PORT=5000
APP_NAME=COSMAN
APP_URL=http://localhost:5000
LOG_LEVEL=info

# ── Database (PostgreSQL via Supabase / Neon / self-hosted) ──
DATABASE_URL=postgresql://cosman:password@localhost:5432/cosman
# For Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# For Neon:     postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/cosman?sslmode=require

# ── Redis (Upstash for serverless, or self-hosted) ──
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=cosmanredis
# For Upstash: rediss://:[TOKEN]@[ENDPOINT]:6380

# ── JWT Secrets — generate with: openssl rand -hex 64 ──
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ── Docker DB (docker-compose only) ──
POSTGRES_DB=cosman
POSTGRES_USER=cosman
POSTGRES_PASSWORD=REPLACE_THIS

# ── Cloudinary (product image uploads) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cosman.com
SMTP_PASS=your_app_password

# ── Stripe (card payments) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── PayPal ──
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# ── WhatsApp Business ──
WHATSAPP_NUMBER=+212600000000

# ── Frontend URL (CORS) ──
FRONTEND_URL=http://localhost:3000
# Production: https://cosman.com
